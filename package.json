{
  "name": "nour-quran",
  "private": true,
  "version": "1.0.0",
  "description": "Nour Quran web app with production-ready Capacitor Android project.",
  "scripts": {
    "build": "npm run build:web",
    "build:web": "node scripts/build-web.mjs",
    "cap:sync": "npm run build:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "dev": "python3 -m http.server 5173",
    "lint": "node scripts/lint-js.mjs",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/core": "^7.4.3",
    "@capacitor/local-notifications": "^7.0.3",
    "@vercel/analytics": "latest",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.6.5"
  }
}
